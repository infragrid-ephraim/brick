{
  "name": "brick-lang",
  "displayName": "Brick Language",
  "description": "Internal language tooling.",
  "version": "0.3.3",
  "publisher": "Infragrid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Infragrid-AI/brick.git"
  },
  "homepage": "https://github.com/Infragrid-AI/brick#readme",
  "icon": "icons/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [],
  "activationEvents": [
    "onLanguage:brick",
    "onUri"
  ],
  "contributes": {
    "languages": [
      {
        "id": "brick",
        "aliases": [
          "Brick",
          "brick"
        ],
        "extensions": [
          ".brick"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/brick-file.svg",
          "dark": "./icons/brick-file.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "brick",
        "scopeName": "source.brick",
        "path": "./syntaxes/brick.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.javascript": "javascript",
          "meta.embedded.block.python": "python"
        }
      }
    ],
    "snippets": [
      {
        "language": "brick",
        "path": "./snippets/brick.json"
      }
    ],
    "commands": [
      {
        "command": "brick.build",
        "title": "Brick: Build",
        "icon": "$(play)"
      },
      {
        "command": "brick.lint",
        "title": "Brick: Lint"
      },
      {
        "command": "brick.signIn",
        "title": "Brick: Sign In"
      },
      {
        "command": "brick.signOut",
        "title": "Brick: Sign Out"
      },
      {
        "command": "brick.installCursorRules",
        "title": "Brick: Install Cursor Rules"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "brick.build",
          "when": "resourceExtname == .brick",
          "group": "navigation"
        }
      ]
    }
  },
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "bundle": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "compile": "tsc -p ./ --noEmit",
    "package": "npm run bundle && npx @vscode/vsce package --no-dependencies",
    "publish": "npm run package && npx @vscode/vsce publish --packagePath brick-lang-0.3.2.vsix --no-dependencies"
  },
  "devDependencies": {
    "@brick/core": "*",
    "@supabase/supabase-js": "^2.49.4",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "typescript": "^5.4.0"
  }
}
